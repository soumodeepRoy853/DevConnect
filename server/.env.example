# Example environment variables for the server app.
# Replace placeholders with real values and DO NOT commit secrets.

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/devconnect?retryWrites=true&w=majority

# JWT signing secret (use a long, random string)
JWT_SECRET=replace_with_a_long_random_string

# Frontend URL (used for CORS / allowed origins)
CLIENT_URL=https://your-frontend.example.com

# Server port (optional)
PORT=5000
